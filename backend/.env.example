# Server Configuration
PORT=5000
NODE_ENV=production

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
# Set OPENAI_MOCK_MODE=true to run demo workflows without calling OpenAI (no billing required)
# Each step type (research, summarize, generate, rewrite, extract, custom) returns realistic mock output
OPENAI_MOCK_MODE=false

# Redis Configuration (Upstash)
REDIS_URL=rediss://default:your_password@your_endpoint:6379

# CORS Configuration
FRONTEND_URLS=http://localhost:5173,http://localhost:5174,https://your-deployed-frontend.vercel.app
